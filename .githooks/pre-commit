#!/usr/bin/env bash
# Pre-commit hook: format and lint staged Python files with ruff

# Find ruff — prefer Mason binary, fall back to PATH
RUFF="${HOME}/.local/share/nvim/mason/bin/ruff"
if [ ! -x "$RUFF" ]; then
    RUFF="$(command -v ruff 2>/dev/null)"
fi
if [ -z "$RUFF" ]; then
    echo "pre-commit: ruff not found (install via Mason or pip), skipping"
    exit 0
fi

# Get staged Python files
STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')
if [ -z "$STAGED" ]; then
    exit 0
fi

# Format staged files, then re-stage
$RUFF format $STAGED
$RUFF check --fix $STAGED

# Re-stage any files that were modified by ruff
for file in $STAGED; do
    if [ -f "$file" ]; then
        git add "$file"
    fi
done

# Final check — abort on unfixable errors (e.g. line too long)
$RUFF check $STAGED
if [ $? -ne 0 ]; then
    echo "pre-commit: ruff found unfixable errors, aborting commit"
    exit 1
fi
