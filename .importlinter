[importlinter]
root_packages =
    services
    adapters
    lib

# Services must not import concrete adapters (protocols are OK).
# FIXME: services import RommHttpAdapter and SteamConfigAdapter for TYPE_CHECKING
# type hints. import-linter cannot distinguish TYPE_CHECKING from runtime imports,
# so these are ignored here. When PM-8 (Type Annotations) introduces Protocols for
# these adapters, remove the ignore_imports and add the adapter modules to
# forbidden_modules instead.
[importlinter:contract:no-adapter-impl-in-services]
name = Services must not import concrete adapter implementations
type = forbidden
source_modules =
    services
forbidden_modules =
    adapters.romm.save_api.v46
    adapters.romm.save_api.v47
    adapters.romm.version_router
    adapters.persistence
ignore_imports =
    services.* -> adapters.romm.http
    services.* -> adapters.steam_config

# Adapters must not import services
[importlinter:contract:no-services-in-adapters]
name = Adapters must not import services
type = forbidden
source_modules =
    adapters
forbidden_modules =
    services

# Utilities (lib/) must not import services or adapters
[importlinter:contract:utilities-independence]
name = Utilities must not import services or adapters
type = forbidden
source_modules =
    lib
forbidden_modules =
    services
    adapters

# Services must be independent of each other
# FIXME: sgdb_artwork -> library_sync is a TYPE_CHECKING import for _pending_sync
# access. Replace with a dict ref or Protocol in PM-8 (Type Annotations).
[importlinter:contract:service-independence]
name = Services must not import other services
type = independence
modules =
    services.library_sync
    services.save_sync
    services.playtime
    services.downloads
    services.firmware
    services.sgdb_artwork
    services.metadata
    services.achievements
ignore_imports =
    services.sgdb_artwork -> services.library_sync
